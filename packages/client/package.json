{
  "name": "@backshift/client",
  "version": "0.1.0",
  "description": "Zero-overhead telemetry client for modern web applications. Under 5kb.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup && node scripts/check-size.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@backshift/schema": "workspace:*",
    "@vitest/coverage-v8": "^2.1.0",
    "happy-dom": "^15.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
