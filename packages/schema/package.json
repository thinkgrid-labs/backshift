{
  "name": "@backshift/schema",
  "version": "0.1.0",
  "description": "Canonical JSON Schema and TypeScript types for Backshift events",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./schema.json": "./src/event.schema.json"
  },
  "files": ["dist", "src/event.schema.json"],
  "scripts": {
    "build": "pnpm run generate && tsup",
    "generate": "json2ts -i src/event.schema.json -o src/generated.ts --no-additionalProperties",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
